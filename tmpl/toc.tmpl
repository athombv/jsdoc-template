<?js
var self = this;
var isGlobalPage;

/**
 * TODO remove this hack when JSDocs fixed this.
 * @param input
 * @returns {*}
 */
function fixEventName(input){
  return input.replace(/"/g, "");
}

?>
<nav class="toc trim">
  <h4 class="toc__title font-weight-bold">Table of Contents</h4>

  <ul class="toc__list">
    <li class="toc__item"><a class="toc__link" href="#introduction">Introduction</a></li>

    <?js if (self.find({kind:'class'}) && doc.classdesc && !doc.hideconstructor) { ?>
    <li class="toc__item"><a class="toc__link" href="#section-constructor">Constructor</a></li>
    <?js } ?>

    <?js if (doc.augments && doc.augments.length) { ?>
    <li class="toc__item">
      <a class="toc__link" href="#section-extends">Extends</a>
    </li>
    <?js } ?>

    <?js
    var members = self.find({ kind: 'member', memberof: isGlobalPage ? { isUndefined: true } : doc.longname });
    if (members && members.length && members.forEach) {
    ?>
    <li class="toc__item">
      <a class="toc__link" href="#section-members">Properties</a>
      <ul class="toc__list toc__list--lvl2">
        <?js members.forEach(function(m) { ?>
        <li class="toc__item">
          <a class="toc__link" title="<?js= m.name ?>" href="#<?js= m.name ?>"><?js= m.name ?></a>
        </li>
        <?js }); ?>
      </ul>
    </li>
    <?js } ?>

    <?js
    var methods = self.find({ kind: 'function', memberof: isGlobalPage ? { isUndefined: true } : doc.longname });
    if (methods && methods.length && methods.forEach) {
    ?>
    <li class="toc__item">
      <a class="toc__link" href="#section-methods">Methods</a>
      <ul class="toc__list toc__list--lvl2">
        <?js methods.forEach(function(m) { ?>
        <li class="toc__item">
          <a class="toc__link" title="<?js= m.name ?>" href="#<?js= m.id ?>"><?js= m.name ?></a>
        </li>
        <?js }); ?>
      </ul>
    </li>
    <?js } ?>

    <?js
    var typedefs = self.find({ kind: 'typedef', memberof: isGlobalPage ? { isUndefined: true } : doc.longname });
    if (typedefs && typedefs.length && typedefs.forEach) {
    ?>
    <li class="toc__item">
      <a class="toc__link" href="#section-type-definitions">Type Definitions</a>
      <ul class="toc__list toc__list--lvl2">
        <?js typedefs.forEach(function(m) { ?>
        <li class="toc__item">
          <a class="toc__link" title="<?js= m.name ?>" href="#<?js= m.id ?>"><?js= m.name ?></a>
        </li>
        <?js }); ?>
      </ul>
    </li>
    <?js } ?>

    <?js
    var events = self.find({ kind: 'event', memberof: isGlobalPage ? { isUndefined: true } : doc.longname });
    if (events && events.length && events.forEach) {
    ?>
    <li class="toc__item">
      <a class="toc__link" href="#section-events">Events</a>
      <ul class="toc__list toc__list--lvl2">
        <?js events.forEach(function(e) {
          e.id = fixEventName(e.id);
          e.name = fixEventName(e.name);
        ?>
        <li class="toc__item">
          <a class="toc__link" title="<?js= e.name ?>" href="#<?js= e.id ?>"><?js= e.name ?></a>
        </li>
        <?js }); ?>
      </ul>
    </li>
    <?js } ?>
  </ul>

</nav>
