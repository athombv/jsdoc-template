<?js
var data = obj;
var self = this;
?>
<section id="<?js= id ?>" class="method component trim">
  <h3 class="method__name"><a data-hash-link class="method__hash-link" href="#<?js= id ?>"></a><?js= name ?></h3>
  <span class="method__function function">
    <?js= data.attribs + name + (data.signature ? data.signature : '') ?>
  </span>

  <div class="method__content trim">
    <?js if (data.summary) { ?>
    <p class="summary"><?js= summary ?></p>
    <?js } ?>

    <?js if (data.description) { ?>
    <div class="description trim">
      <?js= data.description ?>
    </div>
    <?js } ?>

    <?js if (data.type && data.type.names) { ?>
    <h4>Type</h4>
    <ul>
      <li>
        <?js= self.partial('type.tmpl', data.type.names) ?>
      </li>
    </ul>
    <?js } ?>

    <?js= this.partial('details.tmpl', data) ?>

    <?js if (data.fires && fires.length) { ?>
    <h4>Fires</h4>
    <ul>
      <?js fires.forEach(function(f) { ?>
      <li><?js= self.linkto(f) ?></li>
      <?js }); ?>
    </ul>
    <?js } ?>

    <?js if (data.examples && examples.length) { ?>
    <h4>Example<?js= examples.length > 1 ? 's' : '' ?></h4>
    <?js= this.partial('examples.tmpl', examples) ?>
    <?js } ?>
  </div>
</section>
